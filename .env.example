# ============================================
# CivicPulse — Environment Variables
# Copy this file to .env and fill in values
# ============================================

PORT=3000
NODE_ENV=development

# ============================================
# MONGODB URI
# ============================================
# Option 1: Local MongoDB (if installed)
# MONGODB_URI=mongodb://localhost:27017/civicpulse
#
# Option 2: MongoDB Atlas FREE tier (Recommended)
# Steps to get your free URI:
#   1. Go to https://cloud.mongodb.com
#   2. Sign up for free
#   3. Create a FREE cluster (M0 — always free)
#   4. Click "Connect" → "Drivers" → Copy URI
#   5. Replace <password> with your DB user password
#
# DEMO URI for testing (shared read/write — use only for local testing):
MONGODB_URI=mongodb+srv://civicpulse_demo:CivicDemo2024@cluster0.mongodb.net/civicpulse_demo?retryWrites=true&w=majority&appName=Cluster0

# ============================================
# JWT SECRETS — Keep these secret in production
# You can use any random string here for dev
# ============================================
JWT_ACCESS_SECRET=civicpulse_access_super_secret_dev_key_2024
JWT_REFRESH_SECRET=civicpulse_refresh_super_secret_dev_key_2024

# ============================================
# CLIENT URL (for CORS)
# ============================================
CLIENT_URL=http://localhost:5173
